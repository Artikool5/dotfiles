[user]
  name=Dyadyusha Artem
  email=artikool5@yandex.ru
	signingkey = ~/.ssh/id_ed25519.pub

[core]
  editor=nvim
  pager=delta

[commit]
	gpgSign = true

[delta]
  navigate=true

[init]
  defaultBranch=main

[gpg]
	format = ssh

[gpg "ssh"]
	allowedSignersFile = ~/.ssh/allowed_signers

[credential]
	credentialStore = secretservice

[merge]
	tool = meld
  conflictstyle=diff3

[diff]
  colorMoved=default
